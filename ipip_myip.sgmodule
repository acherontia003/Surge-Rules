#!name=IPIP MyIP via Proxy
#!desc=Intercept myip.ipip.net and return the result fetched through the configured policy group. Requires MITM for myip.ipip.net.
#!category=Network
#!arguments=policy=PROXY&script_url=https://raw.githubusercontent.com/acherontia003/Surge-Rules/main/ipip_myip_request.js

[MITM]
hostname = %APPEND% myip.ipip.net

[Script]
ipip-myip-request = type=http-request,pattern=^https:\/\/myip\.ipip\.net\/?.*$,script-path=%script_url%,timeout=10,argument=policy=%policy%
